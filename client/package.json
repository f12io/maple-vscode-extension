{
  "name": "maple-extension-client",
  "description": "Maple Extension Client",
  "author": "F12.io",
  "license": "MIT",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:svelte"
  ],
  "main": "./dist/client/extension.js",
  "contributes": {
    "semanticTokenTypes": [
      {
        "id": "maple-mediaQuery",
        "description": "Media query"
      },
      {
        "id": "maple-utility",
        "description": "Utility classes like flex, block"
      },
      {
        "id": "maple-value",
        "description": "Numeric or color values like 4, red-500"
      },
      {
        "id": "maple-parent-selector",
        "description": "Parent element selectors"
      },
      {
        "id": "maple-self-selector",
        "description": "Self element selectors"
      },
      {
        "id": "maple-child-selector",
        "description": "Child element selectors"
      },
      {
        "id": "maple-separator",
        "description": "separator"
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "maple-mediaQuery": [
            "keyword.control.at-rule.media.css",
            "keyword.control",
            "keyword"
          ],
          "maple-utility": [
            "support.type.property-name.css"
          ],
          "maple-value": [
            "string.quoted.single.css",
            "string.quoted.double.html",
            "meta.attribute.class.html"
          ],
          "maple-parent-selector": [
            "entity.other.attribute-name.class.css"
          ],
          "maple-self-selector": [
            "entity.other.attribute-name.class.css"
          ],
          "maple-child-selector": [
            "entity.other.attribute-name.class.css"
          ],
          "maple-separator": [
            "meta.embedded"
          ]
        }
      }
    ],
    "commands": [
      {
        "command": "maple-intellisense.restart",
        "title": "Maple: Restart Language Server"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0"
  }
}
