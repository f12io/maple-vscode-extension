{
  "name": "maple-vscode-extension",
  "displayName": "Maple CSS",
  "description": "Auto-suggestions, hover, diagnostics, and color swatches for the Maple CSS engine",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:vue",
    "onLanguage:svelte",
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:razor"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "semanticTokenTypes": [
      {
        "id": "maple-mediaQuery",
        "description": "Media query"
      },
      {
        "id": "maple-utility",
        "description": "Utility classes like flex, block"
      },
      {
        "id": "maple-value",
        "description": "Numeric or color values like 4, red-500"
      },
      {
        "id": "maple-parent-selector",
        "description": "Parent element selectors"
      },
      {
        "id": "maple-self-selector",
        "description": "Self element selectors"
      },
      {
        "id": "maple-child-selector",
        "description": "Child element selectors"
      },
      {
        "id": "maple-selector-operator",
        "description": "Selector operators (^, &, /)"
      },
      {
        "id": "maple-separator",
        "description": "Separator"
      },
      {
        "id": "maple-underscore",
        "description": "Underscore separator"
      },
      {
        "id": "maple-alias",
        "description": "Custom alias"
      },
      {
        "id": "maple-variable",
        "description": "Custom variable"
      },
      {
        "id": "maple-important",
        "description": "Important prefix (!)"
      }
    ],
    "semanticTokenScopes": [
      {
        "scopes": {
          "maple-mediaQuery": [
            "keyword.control.at-rule.media.css",
            "keyword.control",
            "keyword"
          ],
          "maple-utility": [
            "support.type.property-name.css"
          ],
          "maple-value": [
            "string.quoted.single.css",
            "string.quoted.double.html",
            "meta.attribute.class.html"
          ],
          "maple-parent-selector": [
            "entity.other.attribute-name.class.css"
          ],
          "maple-self-selector": [
            "entity.other.attribute-name.class.css"
          ],
          "maple-child-selector": [
            "entity.other.attribute-name.class.css"
          ],
          "maple-selector-operator": [
            "keyword.operator.css"
          ],
          "maple-separator": [
            "meta.embedded"
          ],
          "maple-underscore": [
            "punctuation.definition.tag",
            "punctuation.separator",
            "punctuation",
            "meta.embedded"
          ],
          "maple-alias": [
            "entity.name.function"
          ],
          "maple-variable": [
            "variable.css",
            "variable.other.customproperty.css"
          ],
          "maple-important": [
            "keyword.other.important.css",
            "keyword.other.important",
            "keyword"
          ]
        }
      }
    ],
    "commands": [],
    "configuration": {
      "type": "object",
      "title": "Maple CSS",
      "properties": {
        "maple.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Maple CSS extension features in this workspace."
        },
        "maple.exclude": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["**/node_modules/**", "**/.git/**"],
          "description": "Glob patterns for files where Maple CSS extension features should be disabled."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint .",
    "prettier:fix": "prettier --write . --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.43",
    "@types/picomatch": "^4.0.3",
    "@types/vscode": "^1.125.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@f12io/coco": "^2.1.9",
    "@f12io/maple": "^2.0.20",
    "picomatch": "^4.0.4",
    "prettier": "^3.8.4"
  }
}
