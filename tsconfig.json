{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020", "DOM"],
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@f12io/maple-language-core": ["packages/core/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "tests",
    "__mocks__",
    "packages",
    "vitest.config.ts"
  ]
}
